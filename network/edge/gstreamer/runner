#!/bin/bash
# $1 is passed from systemd as %i (e.g., video2)
DEVICE_NAME=$1
DEVICE_NUM=${DEVICE_NAME#video}
PORT=$((5000 + DEVICE_NUM))
RESOLUTION=$(< /opt/gstreamer/settings/resolution)
RES_WIDTH="${RESOLUTION%%,*}"
RES_HEIGHT="${RESOLUTION#*,}"
WIDTH="${RAW_WIDTH:-640}"
HEIGHT="${RAW_HEIGHT:-480}"

# Wait for device to be available
for i in {1..5}; do
    if [ -c "/dev/$DEVICE_NAME" ]; then break; fi
    sleep 1
done

echo "Starting GStreamer on /dev/$DEVICE_NAME at port $PORT with resolution ${WIDTH}x${HEIGHT}"

# exec GStreamer to expose failure to systemd service
exec /usr/bin/gst-launch-1.0 v4l2src device=/dev/$DEVICE_NAME ! \
    image/jpeg,width=$WIDTH,height=$HEIGHT,framerate=30/1 ! jpegdec ! \
    videoconvert ! x264enc tune=zerolatency bitrate=1500 speed-preset=ultrafast ! \
    rtph264pay config-interval=1 pt=96 mtu=1300 ! \
    udpsink host=239.1.1.1 port=$PORT auto-multicast=true sync=false
