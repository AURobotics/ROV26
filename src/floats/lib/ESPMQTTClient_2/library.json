  "keywords": ["mqtt", "esp32", "esp-idf", "wifi", "iot"],
  "authors": {
    "name": "Your Name",
    "email": "your@email.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourname/esp-mqtt-client"
  },
  "license": "MIT",
  "frameworks": "espidf",
  "platforms": "espressif32",
  "build": {
